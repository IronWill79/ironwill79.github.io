---
import Layout from "../../layouts/Layout.astro";
const allPosts = await Astro.glob("../posts/*.md");
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];
const title = "Tag index page";
---

<Layout title={title}>
  <div class="tags">
    {
      tags.map((tag) => (
        <p>
          <a class="tag" href={`/tags/${tag}`}>{tag}</a>
        </p>
      ))
    }
  </div>
</Layout>
