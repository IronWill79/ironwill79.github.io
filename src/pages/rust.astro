---
import Layout from "../layouts/Layout.astro";
const rustForEmbeddedSystemsPosts = await Astro.glob(
  "./rust/introduction-to-embedded-systems-with-rust/*.md",
);
const title = "Rust";
---

<Layout title={title}>
  <p>This is where I will post about my journey learning Python.</p>
  <h3>Introduction to Embedded Systems with Rust</h3>
  <ul>
    {
      rustForEmbeddedSystemsPosts.map((post) => (
        <li>
          <a href={post.url}>{post.frontmatter.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
