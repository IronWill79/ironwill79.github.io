---
import Layout from "../layouts/Layout.astro";
const pythonForNonProgrammersPosts = await Astro.glob(
  "./python/python-for-non-programmers/*.md",
);
const title = "Python";
---

<Layout title={title}>
  <p>This is where I will post about my journey learning Python.</p>
  <h3>Python for Non-Programmers</h3>
  <ul>
    {
      pythonForNonProgrammersPosts.map((post) => (
        <li>
          <a href={post.url}>{post.frontmatter.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
