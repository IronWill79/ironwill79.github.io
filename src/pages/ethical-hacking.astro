---
import Layout from "../layouts/Layout.astro";
const allPosts = await Astro.glob("./ethical-hacking/*.md");
const title = "Ethical Hacking";
---

<Layout title={title}>
  <p>This is where I will post about my journey learning Ethical Hacking.</p>
  <ul>
    {
      allPosts.map((post) => (
        <li>
          <a href={post.url}>{post.frontmatter.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
